# Personal API token from ClickUp (Settings -> Apps -> Generate)
# Paste the raw token. Do NOT prepend "Bearer ".
CLICKUP_API_TOKEN=pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The List that new tasks will be created under.
# Found in the URL: app.clickup.com/.../l/<LIST_ID>
CLICKUP_LIST_ID=901234567890

# Local server port
PORT=3000

# --- LINE Messaging API (optional — leave blank to disable /webhook/line) ---
# Channel access token (long-lived) from LINE Developers Console
# Channel -> Messaging API tab -> "Channel access token"
LINE_CHANNEL_ACCESS_TOKEN=

# Channel secret from LINE Developers Console
# Channel -> Basic settings tab -> "Channel secret"
LINE_CHANNEL_SECRET=

# Comma-separated LINE userIds allowed to create tasks via the bot.
# Leave empty to deny everyone except the "whoami" command (used to bootstrap).
# Example: U1234567890abcdef,U9876543210abcdef
LINE_ALLOWED_USER_IDS=
