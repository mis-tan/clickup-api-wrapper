# Personal API token from ClickUp (Settings -> Apps -> Generate)
# Paste the raw token. Do NOT prepend "Bearer ".
CLICKUP_API_TOKEN=pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The List that new tasks will be created under.
# Found in the URL: app.clickup.com/.../l/<LIST_ID>
CLICKUP_LIST_ID=901234567890

# Local server port
PORT=3000
